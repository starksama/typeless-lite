{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typeless Lite",
  "version": "0.1.0",
  "identifier": "com.typeless.lite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Typeless Lite",
        "width": 1360,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 760,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
